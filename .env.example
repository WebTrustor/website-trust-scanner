# Copy this file to .env and fill in real values
# Never commit .env to git

# ── App ──────────────────────────────────────
APP_ENV=development

# ── Database ─────────────────────────────────
POSTGRES_DB=trustscanner
POSTGRES_USER=trustscanner
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://trustscanner:change_me_strong_password@db:5432/trustscanner

# ── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_64_random_hex_chars_here

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Scan settings ────────────────────────────
SCAN_TIMEOUT_SECONDS=8
SCAN_MAX_REDIRECTS=5
SCAN_MAX_RESPONSE_SIZE_MB=2

# ── Rate limiting ────────────────────────────
RATE_LIMIT_GUEST_PER_HOUR=3
RATE_LIMIT_FREE_USER_PER_DAY=10

# ── Reputation provider ──────────────────────
# mock = no real API calls (MVP default)
# future: google_safe_browsing | virustotal | urlhaus
REPUTATION_PROVIDER=mock
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Admin API key (Phase 5) ──────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Set in X-Admin-Key header for all /api/v1/admin/* requests
ADMIN_API_KEY=change_me_strong_admin_key

# ── Email (Phase 9) ──────────────────────────
EMAIL_PROVIDER=none
EMAIL_FROM=noreply@example.com
