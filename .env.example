# Copy this file to .env and fill in real values
# Never commit .env to git

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=trustscanner
POSTGRES_USER=trustscanner
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://trustscanner:change_me_strong_password@db:5432/trustscanner

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security (JWT + CSRF) ─────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be at least 32 random bytes in production
SECRET_KEY=change_me_64_random_hex_chars_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Access token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7
# Failed login attempts before lockout (default: 5)
MAX_FAILED_LOGINS=5
# Lockout duration in minutes (default: 15)
LOGIN_LOCKOUT_MINUTES=15

# ── Admin API key (fallback from Phase 5, JWT preferred) ─────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=change_me_strong_admin_key

# ── Scan settings ─────────────────────────────────────────────────────────────
SCAN_TIMEOUT_SECONDS=8
SCAN_MAX_REDIRECTS=5
SCAN_MAX_RESPONSE_SIZE_MB=2

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GUEST_PER_HOUR=3
RATE_LIMIT_FREE_USER_PER_DAY=10

# ── Reputation provider ───────────────────────────────────────────────────────
# mock = no external calls (default / MVP)
# google_safe_browsing | virustotal | urlhaus (future)
REPUTATION_PROVIDER=mock
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=
